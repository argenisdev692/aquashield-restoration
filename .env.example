APP_NAME=Vidula
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=r2
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_URL=

R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_DEFAULT_REGION=auto
R2_BUCKET=
R2_URL=
R2_ENDPOINT=
R2_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VITE_GOOGLE_MAPS_API_KEY=

# Resend
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=

# Google Socialite
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# AI Content Generation
TAVILY_API_KEY=
TAVILY_SEARCH_URL=https://api.tavily.com/search
TAVILY_SEARCH_DEPTH=advanced
TAVILY_MAX_RESULTS=5

ANTHROPIC_API_KEY=
ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages
ANTHROPIC_VERSION=2023-06-01

AI_DEFAULT_PROVIDER=anthropic
AI_DEFAULT_MODEL=claude-sonnet-4-6

# Replicate
REPLICATE_API_TOKEN=
REPLICATE_BASE_URL=https://api.replicate.com/v1
REPLICATE_IMAGE_MODEL=black-forest-labs/flux-2-pro
REPLICATE_IMAGE_ASPECT_RATIO=16:9
REPLICATE_IMAGE_OUTPUT_FORMAT=webp
REPLICATE_IMAGE_OUTPUT_QUALITY=85
REPLICATE_IMAGE_SAFETY_TOLERANCE=2
REPLICATE_IMAGE_PROMPT_UPSAMPLING=true
REPLICATE_WAIT_SECONDS=25
REPLICATE_STORAGE_DISK=r2
REPLICATE_STORAGE_DIRECTORY=ai/campaigns
REPLICATE_STORAGE_DIRECTORY_POSTS=ai/posts

# Prism AI / LLM Keys
OPENAI_API_KEY=
GEMINI_API_KEY=

# Reverb WebSocket Configuration
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

# Reverb Advanced Options
REVERB_MAX_REQUEST_SIZE=10000
REVERB_MAX_MESSAGE_SIZE=10000
REVERB_PING_INTERVAL=30
REVERB_PING_TIMEOUT=60

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# OpenTelemetry Configuration
OTEL_SERVICE_NAME="aquashield-laravel"
OTEL_SERVICE_VERSION="1.0.0"
OTEL_RESOURCE_ATTRIBUTES="service.name=aquashield-laravel,service.version=1.0.0"
OTEL_EXPORTER_OTLP_ENDPOINT="https://your-otel-collector.railway.app"
OTEL_EXPORTER_OTLP_HEADERS="x-api-key=your-otel-api-key"
OTEL_EXPORTER_OTLP_PROTOCOL="http/protobuf"
OTEL_EXPORTER_OTLP_COMPRESSION="gzip"

# OpenTelemetry Tracing
OTEL_TRACES_SAMPLER="traceidratio"
OTEL_TRACES_SAMPLER_ARG="1.0"
OTEL_PHP_AUTOLOAD_ENABLED="true"
OTEL_SDK_DISABLED="false"

# OpenTelemetry Metrics
OTEL_METRICS_EXPORTER="otlp"
OTEL_METRIC_EXPORT_INTERVAL="30000"
OTEL_METRIC_EXPORT_TIMEOUT="10000"

# OpenTelemetry Logs
OTEL_LOGS_EXPORTER="otlp"
OTEL_LOG_LEVEL="info"
OTEL_PROPAGATORS="tracecontext,baggage"

# OpenTelemetry Laravel Specific
LARAVEL_TELEMETRY_ENABLED="true"
LARAVEL_TELEMETRY_EXCEPTIONS="true"
LARAVEL_TELEMETRY_QUERIES="true"
LARAVEL_TELEMETRY_REQUESTS="true"
LARAVEL_TELEMETRY_CACHE="true"
LARAVEL_TELEMETRY_QUEUE="true"

