# Variables de entorno para Railway
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-app-url.railway.app
ASSET_URL=https://your-app-url.railway.app

# Base de datos (Railway PostgreSQL)
DB_CONNECTION=pgsql
DB_HOST=RAILWAY_PRIVATE_DB_HOST
DB_PORT=RAILWAY_PRIVATE_DB_PORT
DB_DATABASE=RAILWAY_PRIVATE_DB_NAME
DB_USERNAME=RAILWAY_PRIVATE_DB_USER
DB_PASSWORD=RAILWAY_PRIVATE_DB_PASSWORD

# Cache y Session
CACHE_STORE=redis
SESSION_DRIVER=cookie
QUEUE_CONNECTION=redis

# Logs
LOG_CHANNEL=errorlog
LOG_LEVEL=error

# Seguridad
APP_KEY=base64:your-generated-key-here

# Filesystem (usar Railway's public storage)
FILESYSTEM_DISK=public

# Otras variables necesarias según tu configuración
VITE_APP_NAME="${APP_NAME}"
