# Variables de entorno para Railway - AquaShield
APP_NAME=AquaShield
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-app-url.railway.app
ASSET_URL=https://your-app-url.railway.app

# Base de datos (Railway PostgreSQL)
DB_CONNECTION=pgsql
DB_HOST=RAILWAY_PRIVATE_DB_HOST
DB_PORT=RAILWAY_PRIVATE_DB_PORT
DB_DATABASE=RAILWAY_PRIVATE_DB_NAME
DB_USERNAME=RAILWAY_PRIVATE_DB_USER
DB_PASSWORD=RAILWAY_PRIVATE_DB_PASSWORD

# Cache y Session
CACHE_STORE=redis
SESSION_DRIVER=cookie
QUEUE_CONNECTION=redis

# Logs
LOG_CHANNEL=errorlog
LOG_LEVEL=error

# Seguridad
APP_KEY=base64:your-generated-key-here

# Filesystem (R2 Cloudflare)
FILESYSTEM_DISK=r2

# Cloudflare R2 Configuration
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_DEFAULT_REGION=auto
R2_REGION=auto
R2_BUCKET=aquashield-bucket
R2_ENDPOINT=https://your-r2-endpoint.r2.cloudflarestorage.com
R2_URL=https://your-r2-endpoint.r2.cloudflarestorage.com
R2_USE_PATH_STYLE_ENDPOINT=false

# Reverb WebSocket
REVERB_APP_ID=203142
REVERB_APP_KEY=k6hobagw3c87bamlpzhg
REVERB_APP_SECRET=552iyp9hghmu7zn5rm0q
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=http

# Frontend variables
VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Email (Resend)
EMAIL_PROVIDER=resend
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=noreply@aquashieldrestorationusa.com
EMAIL_FROM_NAME=AquaShieldRestorationLLC

# Google Maps
PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key

# AI Services
RETELL_AI_API_KEY=your-retell-api-key
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GEMINI_API_KEY=your-gemini-api-key

# Social Auth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"
